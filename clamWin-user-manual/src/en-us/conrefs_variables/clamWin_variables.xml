      <table frame="all" rowsep="1" colsep="1" id="table_atc_ggd_nvb">
        <tgroup cols="2">
          <colspec colname="c1" colnum="1" colwidth="1*"/>
          <colspec colname="c2" colnum="2" colwidth="1*"/>
          <thead>
            <row>
              <entry>
                <p>Variable</p>
