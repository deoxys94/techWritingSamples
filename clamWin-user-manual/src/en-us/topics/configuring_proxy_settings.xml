<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<task id="configuring_proxy">
    <title>Proxy Server Configuration</title>
    <shortdesc>Configure <ph conkeyref="ClamWinVARS/short_product_name"/> if you connect to the internet using a proxy server.</shortdesc>
    <taskbody>
        <context/>
        <steps>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_bzn_rtj_4vb"/>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_cdp_zjm_4vb"/>
            </step>
            <step>
                <cmd>In the <wintitle>ClamWin Preferences</wintitle> window, go to the <uicontrol>Proxy</uicontrol> tab.</cmd>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_xt5_dkm_4vb"/>
                <info>
                    <table frame="all" rowsep="1" colsep="1" id="table_pv2_j2m_4vb">
                        <tgroup cols="2">
                            <colspec colname="c1" colnum="1" colwidth="1*"/>
                            <colspec colname="c2" colnum="2" colwidth="3*"/>
                            <thead>
                                <row>
                                    <entry>
                                        <p>Setting</p>
                                    </entry>
                                    <entry>
                                        <p>Description</p>
                                    </entry>
                                </row>
                            </thead>
                            <tbody>
                                <row>
                                    <entry>
                                        <p><uicontrol>Proxy Server</uicontrol></p>
                                    </entry>
                                    <entry><p>IP or FDQN of the proxy server</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Port</uicontrol></p>
                                    </entry>
                                    <entry><p>Port used to establish connection to the proxy server</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>User Name</uicontrol></p>
                                    </entry>
                                    <entry><p>User name of the proxy server</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Password</uicontrol></p>
                                    </entry>
                                    <entry><p>Password of the proxy server</p></entry>
                                </row>
                            </tbody>
                        </tgroup>
                    </table>
                </info>
            </step>
        </steps>
    </taskbody>
</task>
