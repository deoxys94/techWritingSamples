<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<task id="scanning_configuration">
    <title>Scanning Configuration</title>
    <shortdesc>Configure what <ph conkeyref="ClamWinVARS/short_product_name"/> should do when scanning and detecting threats.</shortdesc>
    <taskbody>
        <context/>
        <steps>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_bzn_rtj_4vb"/>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_cdp_zjm_4vb"/>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_xt5_dkm_4vb"/>
                <info>
                    <table frame="all" rowsep="1" colsep="1" id="table_pv2_j2m_4vb">
                        <tgroup cols="2">
                            <colspec colname="c1" colnum="1" colwidth="1*"/>
                            <colspec colname="c2" colnum="2" colwidth="3*"/>
                            <thead>
                                <row>
                                    <entry>
                                        <p>Setting</p>
                                    </entry>
                                    <entry>
                                        <p>Description</p>
                                    </entry>
                                </row>
                            </thead>
                            <tbody>
                                <row>
                                    <entry namest="c1" nameend="c2" align="center">
                                        <p><uicontrol>Scanning Options</uicontrol></p>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Display Infected Files Only</uicontrol></p>
                                    </entry>
                                    <entry><p>If selected, <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> only displays infected files in the scan progress window.</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Scan in Subdirectories</uicontrol></p>
                                    </entry>
                                    <entry>
                                        <p>Allows <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> to scan all nested folders and files.</p>
                                        <note type="important">
                                            <p>When disabled, <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> may not scan all files inside a folder or drive.</p>
                                        </note>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Display File Scanned &#37; Progress Indicator</uicontrol></p>
                                    </entry>
                                    <entry>
                                        <p>If selected, <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> displays a progress indicator.</p>
                                    </entry>
                                </row>
                                <row>
                                    <entry namest="c1" nameend="c2" align="center">
                                        <p><uicontrol>Infected Files</uicontrol></p>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Report Only</uicontrol></p>
                                    </entry>
                                    <entry>
                                        <p>Default option. <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> does not take any action when finding infected files.</p>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Remove</uicontrol></p>
                                    </entry>
                                    <entry>
                                        <p><ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> deletes all infected files.</p>
                                        <note type="warning">
                                            <p>Removing infected files can cause permanent information loss and system instability.</p>
                                        </note>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Move To Quarantine Folder</uicontrol></p>
                                    </entry>
                                    <entry>
                                        <p><ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> moves all infected files to the specified quarantine folder.</p>
                                    </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Unload Infected Programs From Computer Memory</uicontrol></p>
                                    </entry>
                                    <entry><p><ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> attempts to terminate all malicious processes found.</p></entry>
                                </row>
                            </tbody>
                        </tgroup>
                    </table>
                </info>
            </step>
        </steps>
    </taskbody>
</task>
