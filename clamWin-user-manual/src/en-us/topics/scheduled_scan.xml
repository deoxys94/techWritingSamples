<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE task PUBLIC "-//OASIS//DTD DITA Task//EN" "task.dtd">
<task id="scheduled_scan">
    <title>Scheduled Scan</title>
    <shortdesc>Schedule a custom scan to run on the times you choose.</shortdesc>
    <taskbody>
        <context/>
        <steps>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_bzn_rtj_4vb"/>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_cdp_zjm_4vb"/>
            </step>
            <step>
                <cmd>In the <wintitle>ClamWin Preferences</wintitle> window, go to the <uicontrol>Scheduled Scans</uicontrol> tab.</cmd>
            </step>
            <step>
                <cmd>Click <uicontrol>Add</uicontrol>.</cmd>
            </step>
            <step>
                <cmd conref="../conrefs_variables/scan_conref.xml#scan_conref/cmd_xt5_dkm_4vb"/>
                <info>
                    <table frame="all" rowsep="1" colsep="1" id="table_pv2_j2m_4vb">
                        <tgroup cols="2">
                            <colspec colname="c1" colnum="1" colwidth="1*"/>
                            <colspec colname="c2" colnum="2" colwidth="3*"/>
                            <thead>
                                <row>
                                    <entry>
                                        <p>Setting</p>
                                    </entry>
                                    <entry>
                                        <p>Description</p>
                                    </entry>
                                </row>
                            </thead>
                            <tbody>
                                <row>
                                    <entry>
                                        <p><uicontrol>Scanning Frequency</uicontrol></p>
                                    </entry>
                                    <entry><p>Defines the frequency of scans. Available values:</p>
                                    <ul>
                                        <li><p><uicontrol>Hourly</uicontrol></p></li>
                                        <li><p><uicontrol>Daily</uicontrol></p></li>
                                        <li><p><uicontrol>Workdays</uicontrol></p></li>
                                        <li><p><uicontrol>Weekly</uicontrol></p></li>
                                    </ul>
                                </entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Time</uicontrol></p>
                                    </entry>
                                    <entry><p>Time scans run.</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Day Of The Week</uicontrol></p>
                                    </entry>
                                    <entry><p>The day scans run. Only available if you select <uicontrol>Weekly</uicontrol>.</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Activate This Schedule</uicontrol></p>
                                    </entry>
                                    <entry><p>Enables or disables the scheduled scan.</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Scan Programs Loaded in Computer Memory</uicontrol></p>
                                    </entry>
                                    <entry><p>If selected, <ph conkeyref="ClamWinVARS/short_product_name">product_name</ph> scans the programs loaded in your computer memory before beginning the scheduled scan.</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Scan Folder</uicontrol></p>
                                    </entry>
                                    <entry><p>Folder or drive to scan</p></entry>
                                </row>
                                <row>
                                    <entry>
                                        <p><uicontrol>Description</uicontrol></p>
                                    </entry>
                                    <entry><p>Additional information</p></entry>
                                </row>
                            </tbody>
                        </tgroup>
                    </table>
                </info>
            </step>
            <step>
                <cmd>Click <uicontrol>OK</uicontrol>.</cmd>
                <stepresult><ph conkeyref="ClamWinVARS/short_product_name"/> will scan the specified folders or drives at the specified time.</stepresult>
            </step>
        </steps>
    </taskbody>
</task>
