<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE concept PUBLIC "-//OASIS//DTD DITA Concept//EN" "concept.dtd">
<concept id="updating_virus_database_files">
    <title>Updating Virus Database Files</title>
    <shortdesc>Keep <ph conkeyref="ClamWinVARS/short_product_name"> aut</ph> up-to-date by downloading virus signatures from the internet.</shortdesc>
    <conbody>
        <note>
            <p conref="../conrefs_variables/notes_conref.xml#notes_conref/p_bxd_kql_4vb"/>
        </note>
        <p>The following table describes the available methods to update <ph conkeyref="ClamWinVARS/short_product_name"/>'s virus database files</p>
        <table frame="all" rowsep="1" colsep="1" id="table_inw_lpl_4vb">
            <tgroup cols="2">
                <colspec colname="c1" colnum="1" colwidth="1*"/>
                <colspec colname="c2" colnum="2" colwidth="4*"/>
                <thead>
                    <row>
                        <entry>
                            <p>Method</p>
                        </entry>
                        <entry>
                            <p>Description</p>
                        </entry>
                    </row>
                </thead>
                <tbody>
                    <row>
                        <entry>
                            <p>Automatic updates</p>
                        </entry>
                        <entry>
                            <p>By default, <ph conkeyref="ClamWinVARS/short_product_name"> aut</ph> downloads the newest virus database files from the internet once per day.</p>
                            <p>For more information about automatic updates, see {}.</p>
                        </entry>
                    </row>
                    <row>
                        <entry>
                            <p>Update from the main screen</p>
                        </entry>
                        <entry>
                            <p>Open <ph conkeyref="ClamWinVARS/short_product_name"/>'s main screen, then click <ph conkeyref="ClamWinVARS/mainui_update_bd"/> to update <ph conkeyref="ClamWinVARS/short_product_name"/>'s virus database files.</p>
                        </entry>
                    </row>
                </tbody>
            </tgroup>
        </table>
    </conbody>
</concept>
